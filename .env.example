# VoiceSense environment variables
# Copy this file to .env and replace placeholder values with real local or production secrets.
# Never commit real secrets to .env.example.

# AI providers
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# App
DATABASE_URL=postgresql+asyncpg://voicesense:voicesense@localhost:5432/voicesense
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-strong-random-secret

# Voice and messaging providers
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token

# Authentication
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/v1/auth/oauth/google/callback

# STT and TTS provider
CARTESIA_API_KEY=replace-with-cartesia-api-key
CARTESIA_STT_MODEL=ink
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_VOICE_ID=replace-with-cartesia-voice-id
CARTESIA_OUTPUT_FORMAT=pcm_mulaw
CARTESIA_SAMPLE_RATE=8000