# VoiceSense environment variables

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
DATABASE_URL=postgresql+asyncpg://voicesense:voicesense@localhost:5432/voicesense
REDIS_URL=redis://localhost:6379/0
